{
  "name": "@nextera.one/tickauth-server",
  "version": "1.2.0",
  "description": "TickAuth server runtime — capsule store, retrieval, and delegation foundations",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "tickauth",
    "authorization",
    "temporal",
    "capsule",
    "server"
  ],
  "author": "Nextera.one",
  "license": "MIT",
  "dependencies": {
    "@nextera.one/tickauth-sdk": "^1.4.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
