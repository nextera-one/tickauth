{
  "name": "@nextera.one/tickauth-sdk",
  "version": "1.5.0",
  "description": "TypeScript/JavaScript SDK for TickAuth - Temporal Authorization Protocol",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.mjs",
      "require": "./dist/core/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "prepare": "npm run build"
  },
  "author": "NextEra.One",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/digital-pages-co/axis.git",
    "directory": "tickauth-sdk"
  },
  "homepage": "https://tickauth.io",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.0.3",
    "prettier": "^3.7.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@nextera.one/tps-standard": "^0.7.0",
    "@noble/ed25519": "^3.0.0",
    "@noble/hashes": "^2.0.1",
    "ulid": "^3.0.2"
  }
}
